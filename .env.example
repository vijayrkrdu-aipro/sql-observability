# Copy to .env (which is gitignored) ONLY if a connection uses SQL auth
# (integrated_auth: false in config.yaml). With Integrated auth, leave this empty.
# Never commit a real .env. Never log these values.

# Repository instance (only if repository.integrated_auth: false)
# REPO_SQL_USER=
# REPO_SQL_PASSWORD=

# Monitored instance (only if a monitored_instances entry has integrated_auth: false)
# Use the instance name (uppercased, non-alphanumerics -> _) as the prefix, e.g. PROD-SQL-01:
# PROD_SQL_01_USER=
# PROD_SQL_01_PASSWORD=
